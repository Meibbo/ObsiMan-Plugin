filters:
  and:
    - 'file.ext == "md"'
    - 'file.inFolder(".agents/docs/work")'
    - 'file.hasTag("agent/item")'

properties:
  id:
    displayName: "ID"
  type:
    displayName: "Type"
  status:
    displayName: "Status"
  priority:
    displayName: "Priority"
  initiative:
    displayName: "Initiative"
  task_size:
    displayName: "Task Size"
  actual_size:
    displayName: "Actual Size"
  updated:
    displayName: "Updated"

views:
  - type: table
    name: "Active"
    filters:
      and:
        - 'status != "done"'
        - 'status != "wont-do"'
        - 'status != "superseded"'
    order:
      - id
      - file.name
      - type
      - status
      - priority
      - initiative
      - task_size
      - updated

  - type: table
    name: "Bugs"
    filters:
      and:
        - 'type == "bug"'
        - 'status != "done"'
        - 'status != "wont-do"'
        - 'status != "superseded"'
    order:
      - id
      - file.name
      - status
      - priority
      - updated

  - type: table
    name: "Regressions"
    filters:
      and:
        - 'type == "regression"'
        - 'status != "done"'
        - 'status != "wont-do"'
        - 'status != "superseded"'
    order:
      - id
      - file.name
      - status
      - priority
      - updated

  - type: table
    name: "Conflicts"
    filters:
      and:
        - 'type == "conflict"'
        - 'status != "done"'
        - 'status != "wont-do"'
        - 'status != "superseded"'
    order:
      - id
      - file.name
      - status
      - priority
      - updated

  - type: table
    name: "Done"
    filters:
      and:
        - 'status == "done"'
    order:
      - id
      - file.name
      - type
      - actual_size
      - verification
      - updated
