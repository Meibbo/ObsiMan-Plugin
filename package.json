{
	"name": "vaultman",
	"version": "1.0.0-rc.1",
	"description": "Bulk data & metadata editor for vault management in Obsidian",
	"keywords": [],
	"license": "MIT",
	"author": "Meibbo",
	"type": "module",
	"main": "main.js",
	"scripts": {
		"dev": "vp build --watch",
		"build": "tsc -noEmit -skipLibCheck && vp build && node scripts/sync-test-build.mjs",
		"build:plugin": "tsc -noEmit -skipLibCheck && vp build",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "vp lint && eslint .",
		"lint:fast": "vp lint",
		"lint:full": "eslint .",
		"format": "pnpm run format:ox && pnpm run format:prettier",
		"format:check": "pnpm run format:ox:check && pnpm run format:prettier:check",
		"format:ox": "vp fmt",
		"format:ox:check": "vp fmt --check",
		"format:prettier": "prettier --write \"**/*.svelte\"",
		"format:prettier:check": "prettier --check \"**/*.svelte\"",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"test:integrity": "vp test run --project integration --config vitest.config.ts",
		"test:unit": "vp test run --project unit --config vitest.config.ts",
		"test:component": "vp test run --project component --config vitest.config.ts --fileParallelism=false",
		"test:cover": "vp test run --project unit --coverage --config vitest.config.ts",
		"test:e2e": "wdio run ./wdio.conf.mts",
		"test:all": "pnpm run test:integrity && pnpm run test:e2e",
		"verify": "pnpm run lint && pnpm run check && pnpm run build && pnpm run test:unit && pnpm run test:component",
		"audit:dead-exports": "ts-prune",
		"audit:knip": "knip --reporter compact",
		"audit:depcheck": "depcheck --ignores=\"@types/*,obsidian-integration-testing,wdio-obsidian-service\"",
		"audit:all": "pnpm run audit:dead-exports ; pnpm run audit:knip ; pnpm run audit:depcheck"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tanstack/svelte-virtual": "3.13.24",
		"@tanstack/table-core": "8.21.3",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^22.0.0",
		"@vitest/coverage-v8": "^4.1.5",
		"@wdio/cli": "^9.27.0",
		"@wdio/globals": "^9.17.0",
		"@wdio/local-runner": "^9.27.0",
		"@wdio/mocha-framework": "^9.27.0",
		"@wdio/spec-reporter": "^9.27.0",
		"depcheck": "^1.4.7",
		"esbuild": "^0.28.0",
		"esbuild-sass-plugin": "^3.7.0",
		"esbuild-svelte": "^0.9.4",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.2.9",
		"eslint-plugin-oxlint": "^1.62.0",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"js-yaml": "^4.1.1",
		"jsdom": "^29.1.1",
		"knip": "^6.8.0",
		"mocha": "^10.8.2",
		"obsidian": "latest",
		"obsidian-integration-testing": "^2.3.5",
		"obsidian-launcher": "^3.0.2",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"sass": "^1.81.0",
		"svelte": "^5.55.1",
		"svelte-check": "^4.1.0",
		"svelte-preprocess": "^6.0.3",
		"ts-prune": "^0.10.3",
		"type-fest": "^4.41.0",
		"typescript": "~5.8.0",
		"typescript-eslint": "^8.59.1",
		"vite-plus": "^0.1.20",
		"vitest": "^4.1.0",
		"wdio-obsidian-reporter": "^3.0.2",
		"wdio-obsidian-service": "^3.0.2"
	},
	"packageManager": "pnpm@10.29.2",
	"pnpm": {
		"onlyBuiltDependencies": [
			"@parcel/watcher",
			"classic-level",
			"edgedriver",
			"esbuild",
			"geckodriver",
			"obsidian-integration-testing",
			"svelte-preprocess"
		]
	},
	"dependencies": {
		"@git-diff-view/svelte": "^0.1.3",
		"@svar-ui/svelte-filemanager": "^2.5.0"
	}
}
