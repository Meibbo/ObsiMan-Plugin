		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"obsidian": "latest",
		"typescript": "~5.8.0",
		"typescript-eslint": "8.35.1"
	}
