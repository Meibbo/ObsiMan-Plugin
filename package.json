{
	"name": "vaultman",
	"version": "1.0.0-beta.19",
	"description": "Bulk data & metadata editor for vault management in Obsidian",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && node scripts/sync-test-build.mjs",
		"build:plugin": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"test:integrity": "vitest run --project integration --config vitest.config.ts",
		"test:unit": "vitest run --project unit --config vitest.config.ts",
		"test:cover": "vitest run --project unit --coverage --config vitest.config.ts",
		"test:e2e": "wdio run ./wdio.conf.mts",
		"test:all": "npm run test:integrity && npm run test:e2e",
		"verify": "npm run lint && npm run check && npm run build && npm run test:unit",
		"audit:dead-exports": "ts-prune",
		"audit:knip": "knip --reporter compact",
		"audit:depcheck": "depcheck --ignores=\"@types/*,obsidian-integration-testing,wdio-obsidian-service\"",
		"audit:all": "npm run audit:dead-exports ; npm run audit:knip ; npm run audit:depcheck"
	},
	"keywords": [],
	"author": "Meibbo",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^22.0.0",
		"@vitest/coverage-v8": "^4.1.5",
		"@wdio/cli": "^9.27.0",
		"@wdio/globals": "^9.17.0",
		"@wdio/local-runner": "^9.27.0",
		"@wdio/mocha-framework": "^9.27.0",
		"@wdio/spec-reporter": "^9.27.0",
		"depcheck": "^1.4.7",
		"esbuild": "^0.28.0",
		"esbuild-sass-plugin": "^3.7.0",
		"esbuild-svelte": "^0.9.4",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.2.9",
		"eslint-plugin-unused-imports": "^4.4.1",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"js-yaml": "^4.1.1",
		"knip": "^6.8.0",
		"mocha": "^10.8.2",
		"obsidian": "latest",
		"obsidian-integration-testing": "^2.3.5",
		"obsidian-launcher": "^3.0.2",
		"sass": "^1.81.0",
		"svelte": "^5.55.1",
		"svelte-check": "^4.1.0",
		"svelte-preprocess": "^6.0.3",
		"ts-prune": "^0.10.3",
		"type-fest": "^4.41.0",
		"typescript": "~5.8.0",
		"typescript-eslint": "^8.59.1",
		"vitest": "^4.1.0",
		"wdio-obsidian-reporter": "^3.0.2",
		"wdio-obsidian-service": "^3.0.2"
	}
}
