{
	"name": "vaultman",
	"version": "1.0.0-beta.16",
	"description": "Bulk property & file editor for vault management in Obsidian",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && node scripts/sync-test-build.mjs",
		"build:plugin": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"test:integrity": "vitest run --config vitest.config.ts",
		"test:e2e": "wdio run ./wdio.conf.mts",
		"test:all": "npm run test:integrity && npm run test:e2e"
	},
	"keywords": [],
	"author": "Meibbo",
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^22.0.0",
		"@wdio/cli": "^9.27.0",
		"@wdio/globals": "^9.17.0",
		"@wdio/local-runner": "^9.27.0",
		"@wdio/mocha-framework": "^9.27.0",
		"@wdio/spec-reporter": "^9.27.0",
		"esbuild": "^0.28.0",
		"esbuild-sass-plugin": "^3.7.0",
		"esbuild-svelte": "^0.9.4",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"mocha": "^10.8.2",
		"obsidian": "latest",
		"obsidian-integration-testing": "^1.1.2",
		"obsidian-launcher": "^3.0.2",
		"sass": "^1.81.0",
		"svelte": "^5.55.1",
		"svelte-check": "^4.1.0",
		"svelte-preprocess": "^6.0.3",
		"type-fest": "^4.41.0",
		"typescript": "~5.8.0",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.1.0",
		"wdio-obsidian-reporter": "^3.0.2",
		"wdio-obsidian-service": "^3.0.2"
	}
}
